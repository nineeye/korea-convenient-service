<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>자동 저장 임시 메모장</title>
    <style>
        /* 기본 리셋 및 폰트 설정 (이전 도구들과 통일) */
        * { box-sizing: border-box; }
        body { 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif; 
            background-color: #f4f7f6; 
            padding: 40px 20px; 
            display: flex; 
            justify-content: center; 
            margin: 0;
            height: 100vh; /* 화면 전체 높이 사용 */
        }
        
        .container { 
            background: white; 
            padding: 30px; 
            border-radius: 12px; 
            box-shadow: 0 4px 15px rgba(0,0,0,0.05); 
            width: 100%; 
            max-width: 800px; 
            display: flex;
            flex-direction: column;
        }
        
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        h2 { margin: 0; color: #2c3e50; font-size: 24px; }
        
        /* 저장 상태 표시 텍스트 */
        .save-status {
            font-size: 14px;
            color: #2ecc71;
            font-weight: bold;
            opacity: 0; /* 기본적으로 안보이게 처리 */
            transition: opacity 0.3s ease;
        }

        /* 텍스트 입력창 (메모장 영역) */
        textarea { 
            flex-grow: 1; /* 남은 공간을 모두 차지하도록 설정 */
            width: 100%; 
            min-height: 400px;
            padding: 20px; 
            border: 2px solid #e2e8f0; 
            border-radius: 8px; 
            font-size: 16px; 
            line-height: 1.6;
            resize: none; /* 크기 조절 막음 (flex로 자동 조절되므로) */
            margin-bottom: 20px; 
            transition: border-color 0.3s ease;
            background-color: #fafbfc;
        }
        textarea:focus { 
            outline: none; 
            border-color: #3498db; 
            background-color: #ffffff;
        }
        
        /* 버튼 영역 */
        .buttons { display: flex; gap: 10px; }
        button { 
            flex: 1; 
            padding: 14px; 
            border: none; 
            border-radius: 8px; 
            cursor: pointer; 
            font-size: 16px; 
            font-weight: 600; 
            transition: all 0.2s ease; 
        }
        button:active { transform: scale(0.98); }
        
        .btn-copy { background: #3498db; color: white; }
        .btn-copy:hover { background: #2980b9; }
        .btn-clear { background: #e74c3c; color: white; }
        .btn-clear:hover { background: #c0392b; }
    </style>
</head>
<body>

    <div class="container">
        <div class="header">
            <h2>임시 메모장</h2>
            <span class="save-status" id="saveStatus">✓ 자동 저장됨</span>
        </div>
        
        <textarea id="noteInput" placeholder="여기에 메모를 작성하세요. 타이핑하는 즉시 브라우저에 자동 저장됩니다..."></textarea>

        <div class="buttons">
            <button class="btn-copy" onclick="copyNote()">내용 복사하기</button>
            <button class="btn-clear" onclick="clearNote()">전체 지우기</button>
        </div>
    </div>

    <script>
        const noteInput = document.getElementById('noteInput');
        const saveStatus = document.getElementById('saveStatus');
        let saveTimeout;

        // 1. 페이지 로드 시 기존에 저장된 메모 불러오기
        // 브라우저의 로컬 스토리지에 'savedNote'라는 이름으로 저장된 데이터가 있는지 확인합니다.
        window.onload = function() {
            const savedText = localStorage.getItem('savedNote');
            if (savedText) {
                noteInput.value = savedText;
            }
        };

        // 2. 타이핑할 때마다 자동 저장하기
        noteInput.addEventListener('input', function() {
            // 현재 텍스트를 로컬 스토리지에 덮어쓰기
            localStorage.setItem('savedNote', noteInput.value);

            // '자동 저장됨' 메시지 띄우기 (타이핑 시 나타났다가 2초 후 서서히 사라짐)
            saveStatus.style.opacity = '1';
            
            clearTimeout(saveTimeout);
            saveTimeout = setTimeout(() => {
                saveStatus.style.opacity = '0';
            }, 2000);
        });

        // 3. 내용 복사 기능
        function copyNote() {
            const text = noteInput.value;
            if (text.trim() === '') {
                alert('복사할 메모가 없습니다.');
                return;
            }
            
            navigator.clipboard.writeText(text).then(() => {
                alert('메모가 클립보드에 복사되었습니다.');
            }).catch(err => {
                alert('복사에 실패했습니다: ' + err);
            });
        }

        // 4. 전체 지우기 기능 (실수로 지우는 것을 방지하기 위해 확인 창 띄움)
        function clearNote() {
            if (noteInput.value.trim() === '') return; // 이미 비어있으면 무시

            const confirmDelete = confirm('정말 모든 메모를 지우시겠습니까? (삭제 후 복구할 수 없습니다)');
            if (confirmDelete) {
                noteInput.value = '';
                localStorage.removeItem('savedNote'); // 로컬 스토리지에서도 완전히 삭제
                noteInput.focus();
            }
        }
    </script>

</body>
</html>
